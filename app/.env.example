# Agentic Wallets - Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# AGENT PRIVATE KEYS (Base58 Encoded)
# =============================================================================
# These are the private keys for your AI agent wallets.
# ⚠️  NEVER commit these to version control!
# ⚠️  NEVER expose these in the frontend!
# ⚠️  Store securely and back up offline!
#
# To generate new keys, run: npm run generate-keys
# Or use the Solana CLI: solana-keygen new --outfile agent-1.json

# Agent 1 - Alpha Trader (Conservative Strategy)
VITE_AGENT_1_PRIVATE_KEY=your_agent_1_private_key_here_base58_encoded

# Agent 2 - Beta Analyzer (Moderate Strategy)
VITE_AGENT_2_PRIVATE_KEY=your_agent_2_private_key_here_base58_encoded

# Agent 3 - Gamma Monitor (Aggressive Strategy)
VITE_AGENT_3_PRIVATE_KEY=your_agent_3_private_key_here_base58_encoded

# =============================================================================
# SOLANA NETWORK CONFIGURATION
# =============================================================================

# RPC Endpoint (defaults to public Devnet if not set)
# VITE_SOLANA_RPC_URL=https://api.devnet.solana.com

# Commitment Level (processed, confirmed, or finalized)
# VITE_COMMITMENT_LEVEL=confirmed

# =============================================================================
# OPTIONAL CONFIGURATION
# =============================================================================

# Auto-start agents on initialization (true/false)
# VITE_AUTO_START_AGENTS=false

# Default agent interval in milliseconds
# VITE_AGENT_INTERVAL_MS=15000

# Enable debug logging (true/false)
# VITE_DEBUG_MODE=false

# =============================================================================
# SECURITY NOTES
# =============================================================================
# 
# 1. This file (.env) should be in .gitignore
# 2. Never share private keys with anyone
# 3. Use Devnet only for testing
# 4. Rotate keys periodically
# 5. Monitor agent activity regularly
#
# For production deployment:
# - Use hardware security modules (HSM) or key management services
# - Implement multi-signature requirements
# - Set up monitoring and alerting
# - Use dedicated RPC endpoints
# - Enable rate limiting
